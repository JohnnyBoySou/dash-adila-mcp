# URL base do control plane da Adila (sem barra final).
ADILA_API_URL=https://api.adila.co

# Chave de API da organização (formato adila_sk_...).
# Gere em Configurações → Chaves de API. Mostrada apenas uma vez na criação.
# NUNCA versione o .env real nem compartilhe a chave.
ADILA_API_KEY=adila_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
